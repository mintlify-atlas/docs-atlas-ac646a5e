  "keyFeatures": [
    "Custom document model — avoids contenteditable/execCommand inconsistencies",
    "Web Components via Custom Elements (<trix-editor> and <trix-toolbar>)",
    "Programmatic Editor API for inserting, selecting, and formatting text",
    "File and image attachment support with drag-and-drop",
    "Built-in undo/redo with unlimited history",
    "HTML sanitization via DOMPurify",
    "Form integration with hidden input and constraint validation",
    "Accessible — supports labels, aria-label, aria-labelledby, and :disabled",
    "ESM and UMD distribution formats",
    "Ruby on Rails / Action Text integration"
  ],
